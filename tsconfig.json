{
	"compilerOptions": {
		"baseUrl": ".",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES2020",
		"allowJs": true,
		"noImplicitAny": true,
		"moduleResolution": "node",
		"importHelpers": true,
		"isolatedModules": true,
		"strict": true,
		"strictNullChecks": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"lib": [
			"DOM",
			"ES5",
			"ES6",
			"ES7",
			"ES2020"
		],
		"types": [
			"node"
		]
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.d.ts",
		"tests/**/*.ts"
	]
}
